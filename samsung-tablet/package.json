{
  "name": "vintaste-samsung-tablet",
  "version": "1.0.0",
  "private": true,
  "description": "Android-оболочка Wine Quiz для планшета Samsung (WebView → vintaste.ru)",
  "scripts": {
    "icons": "node scripts/copy-icons.mjs",
    "cap:sync": "npx cap sync android",
    "android:debug": "cd android && .\\gradlew.bat assembleDebug",
    "android:release": "node scripts/ensure-keystore.mjs && cd android && .\\gradlew.bat assembleRelease",
    "install:release": "node scripts/install-release.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "sharp": "^0.34.2",
    "typescript": "^5.8.3"
  },
  "capacitor": {
    "platforms": [
      "android"
    ]
  }
}
